# Git / VCS
.git
.gitignore
.githooks

# Local SQLite databases — never bake these into images
**/*.sqlite3
**/*.sqlite3-shm
**/*.sqlite3-wal
**/*.db

# Python caches and virtualenvs
**/__pycache__
**/*.pyc
**/.venv
**/.pytest_cache
**/.ruff_cache

# Node / JS
**/node_modules

# Editor / OS junk
.DS_Store
**/.DS_Store
.idea
.vscode

# Logs
**/*.log
logs/

# Local secrets (only mount via volumes if needed)
.env
.env.*
secrets.yml
secrets.yaml

# Deployment artifacts and keys
deployments/**/*.pem
deployments/**/*.pub
deployments/**/db-password.txt
docs/
README.md
