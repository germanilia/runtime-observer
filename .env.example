# Runtime Observer minimal process settings
# Secrets, including the SQLite connection string, live in secrets.yml.
RUNTIME_OBSERVER_HOST=127.0.0.1
RUNTIME_OBSERVER_PORT=4319
RUNTIME_OBSERVER_SECRETS=secrets.yml
RUNTIME_OBSERVER_INSECURE_DEV=false
RUNTIME_OBSERVER_RETENTION_DAYS=7
RUNTIME_OBSERVER_REGULAR_LOG_RETENTION_HOURS=4
RUNTIME_OBSERVER_RAW_EVENT_RETENTION_HOURS=24
RUNTIME_OBSERVER_INGEST_QUEUE_BACKEND=sqs
RUNTIME_OBSERVER_SQS_ENDPOINT_URL=http://localhost:4566
RUNTIME_OBSERVER_SQS_QUEUE_URL=http://localhost:4566/000000000000/runtime-observer-ingest
AWS_DEFAULT_REGION=us-east-1
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test

# SDK settings for instrumented apps are copied from the dashboard project screen.
# RUNTIME_OBSERVER_ENDPOINT=http://127.0.0.1:4319
# RUNTIME_OBSERVER_PROJECT_NAME=my-project
# RUNTIME_OBSERVER_SERVICE_NAME=my-service
# RUNTIME_OBSERVER_API_KEY=ro_xxxxxxxx_project_key_from_dashboard
