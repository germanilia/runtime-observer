# Runtime Observer collector settings
RUNTIME_OBSERVER_HOST=127.0.0.1
RUNTIME_OBSERVER_PORT=4319
RUNTIME_OBSERVER_API_KEY=replace-me
RUNTIME_OBSERVER_DASHBOARD_USERNAME=admin
RUNTIME_OBSERVER_DASHBOARD_PASSWORD=replace-me
RUNTIME_OBSERVER_DB=collector/runtime_observer.sqlite3
RUNTIME_OBSERVER_INSECURE_DEV=false
RUNTIME_OBSERVER_RETENTION_DAYS=7

# SDK settings for instrumented apps
RUNTIME_OBSERVER_ENDPOINT=http://127.0.0.1:4319/v1/ingest
RUNTIME_OBSERVER_SERVICE_NAME=my-service
RUNTIME_OBSERVER_PROJECT_NAME=my-project
RUNTIME_OBSERVER_ENABLED=true
