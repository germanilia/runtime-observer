# Homeserver environment for the Runtime Observer collector.
# Loaded by docker-compose.homeserver.yml via `env_file`.
# Never commit real secrets here — replace anything sensitive with a strong
# value before the first deploy and rotate via `just deploy-homeserver`.

# --- Server ---------------------------------------------------------------
RUNTIME_OBSERVER_HOST=0.0.0.0
RUNTIME_OBSERVER_PORT=4319

# --- Persistence ---------------------------------------------------------
# Mounted from the `collector_data` named volume inside the container.
RUNTIME_OBSERVER_DATABASE_URL=sqlite:////data/runtime_observer.sqlite3

# --- Auth ----------------------------------------------------------------
# Insecure dev mode disables dashboard session auth. MUST stay false on the
# homeserver — the first dashboard login at https://metrics.homeserver creates
# the admin user.
RUNTIME_OBSERVER_INSECURE_DEV=false

# --- Ingest pipeline ------------------------------------------------------
# `direct` writes events straight to SQLite. No SQS / LocalStack required.
RUNTIME_OBSERVER_INGEST_QUEUE_BACKEND=direct

# --- Retention -----------------------------------------------------------
RUNTIME_OBSERVER_RETENTION_DAYS=7
RUNTIME_OBSERVER_REGULAR_LOG_RETENTION_HOURS=4
RUNTIME_OBSERVER_RAW_EVENT_RETENTION_HOURS=24
RUNTIME_OBSERVER_TRACE_RETENTION_DAYS=3
RUNTIME_OBSERVER_DURATION_RETENTION_DAYS=3
RUNTIME_OBSERVER_EXCEPTION_RETENTION_DAYS=90
RUNTIME_OBSERVER_AGGREGATE_RETENTION_DAYS=365
RUNTIME_OBSERVER_CLEANUP_INTERVAL_SECONDS=300
